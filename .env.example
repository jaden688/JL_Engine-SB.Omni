# Copy to `.env` and fill in secrets. `.env` is gitignored.
# Reference: DOCKER.md

# --- SparkByte (Web UI + WebSocket) ---
SPARKBYTE_HOST=127.0.0.1
SPARKBYTE_PORT=8081
# Docker / compose host port mapping (compose only)
SPARKBYTE_PUBLIC_PORT=8081
SPARKBYTE_LAUNCH_BROWSER=1
# Leave empty for default project root; Docker sets /app/runtime via compose
# SPARKBYTE_ROOT=
# SPARKBYTE_STATE_DIR=

# --- A2A (Agent-to-Agent) — JSON-RPC + agent card on second port ---
A2A_HOST=127.0.0.1
A2A_PORT=8082
A2A_PUBLIC_PORT=8082
# Public URL in agent.json (use https + host behind reverse proxy in prod)
A2A_PUBLIC_URL=http://localhost:8082
# Set for any internet-exposed deployment (Bearer token)
# A2A_API_KEY=

# --- Julian MetaMorph bridge (optional; auto-detected under ./JulianMetaMorph/JulianMetaMorph) ---
# JULIAN_ROOT=
# JULIAN_DB=
# MCP / tools: seconds between autonomous curiosity hunts; 0 = disabled
JULIAN_AUTONOMOUS_SECONDS=0

# --- LLM & tools ---
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# CEREBRAS_API_KEY=
# Higher rate limits for Julian GitHub hunts
# GITHUB_TOKEN=

# --- Ollama (Docker: host gateway) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- MCP server (Cursor / IDE) — optional overrides ---
# JULIAN_SKILL=
