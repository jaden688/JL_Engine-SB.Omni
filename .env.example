# Copy to `.env` and fill in secrets. `.env` is gitignored.
# Reference: DOCKER.md

# --- SparkByte (Web UI + WebSocket) ---
SPARKBYTE_HOST=127.0.0.1
SPARKBYTE_PORT=8081
# Docker / compose host port mapping (compose only)
SPARKBYTE_PUBLIC_PORT=8081
SPARKBYTE_LAUNCH_BROWSER=1
# Leave empty for default project root; Docker sets /app/runtime via compose
# SPARKBYTE_ROOT=
# SPARKBYTE_STATE_DIR=

# --- A2A (Agent-to-Agent) — JSON-RPC + agent card on second port ---
A2A_HOST=127.0.0.1
A2A_PORT=8082
A2A_PUBLIC_PORT=8082
# Public URL in agent.json (use https + host behind reverse proxy in prod)
A2A_PUBLIC_URL=http://localhost:8081
# Set for any internet-exposed deployment (Bearer token)
# A2A_API_KEY=
# Optional separate admin key for billing/status and billing/link RPC methods
# A2A_ADMIN_KEY=
# Per-key request quota (POST / and /a2a). 0 disables throttling.
A2A_MAX_REQUESTS_PER_MINUTE=0
# Enforce paid subscription on tasks/send (0/1)
A2A_BILLING_ENFORCE=0
# Optional billing/metering rates used by usage/get (USD)
# A2A_PRICE_PER_1K_REQUESTS=0.00
# A2A_PRICE_PER_1K_INPUT_CHARS=0.00
# A2A_PRICE_PER_1K_OUTPUT_CHARS=0.00
# A2A_PRICE_PER_TOOL_CALL=0.00
# Stripe integration for billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_SUBSCRIPTION=
# Checkout/session URLs used by billing/checkout and billing/portal
# A2A_BILLING_SUCCESS_URL=https://yourapp.example.com/billing/success
# A2A_BILLING_CANCEL_URL=https://yourapp.example.com/billing/cancel
# A2A_BILLING_PORTAL_RETURN_URL=https://yourapp.example.com/settings/billing
# Optional hosted links if you want a quick launch without Stripe API wiring
# A2A_BILLING_PAYMENT_LINK_URL=https://buy.stripe.com/...
# A2A_BILLING_PORTAL_URL=https://billing.stripe.com/p/session/...

# --- Julian MetaMorph bridge (optional; auto-detected under ./JulianMetaMorph/JulianMetaMorph) ---
# JULIAN_ROOT=
# JULIAN_DB=
# Seconds between autonomous curiosity hunts (default: 3600 = hourly). Set -1 to disable.
# JULIAN_AUTONOMOUS_SECONDS=3600
# Auto-start a managed Julian MetaMorph service from SparkByte and shut it down with the engine.
# Set to 0 if you want to keep Julian fully standalone.
# JULIAN_MANAGED_SERVICE=1

# --- LLM & tools ---
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# CEREBRAS_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# Higher rate limits for Julian GitHub hunts
# GITHUB_TOKEN=
# REDDIT_SUBREDDIT=
# REDDIT_USER_AGENT=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_REFRESH_TOKEN=
# REDDIT_ACCESS_TOKEN=

# Dynamic forged-tool lifecycle
# Auto-quarantine forged tool after this many dispatch failures
SPARKBYTE_TOOL_FAILURE_THRESHOLD=3

# --- Ollama (Docker: host gateway) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- MCP server (Cursor / IDE) — optional overrides ---
# JULIAN_SKILL=
